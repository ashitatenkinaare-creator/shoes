# Supabase Dashboard → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# サーバー専用（同期 Cron / E2E auth helper 用・Git に含めない）
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# KicksDB → radar_sneakers 同期
# https://kicks.dev/register で取得
KICKSDB_API_KEY=KICKS-XXXX-XXXX

# 手動/Cron 同期の認証（本番では必須）
CRON_SECRET=your-random-secret

# 同期オプション（任意）
# KICKSDB_SYNC_DAYS_AHEAD=30
# KICKSDB_SYNC_DAYS_BEHIND=3
# KICKSDB_SYNC_LIMIT=20
# KICKSDB_USD_JPY=150
# KICKSDB_ANNOUNCE_OFFSET_DAYS=14

# LLM 通知文案生成（サーバー専用・Git に含めない）
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# DISABLE_LLM_NOTIFICATIONS=1

# Web Push（Phase 2・サーバー専用）
# npx web-push generate-vapid-keys で生成
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # クライアント用（公開鍵と同じ値）
# VAPID_SUBJECT=mailto:demo@sneaker-radar.app

# GitHub MCP（Cursor 用・Git に含めない）
# GITHUB_TOKEN=ghp_xxxx
